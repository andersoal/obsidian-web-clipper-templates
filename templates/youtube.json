{
  "schemaVersion": "0.2.0",
  "name": "YouTube",
  "behavior": "create",
  "path": "PKM/Clippings/Videos",
  "noteNameFormat": "{{schema:@VideoObject:uploadDate|date:\"YYYY-MM-DD\"|safe_name}} VIDEO {{schema:author|safe_name|trim}} – {{schema:name|safe_name|trim}}",
  "noteContentFormat": "![{{schema:name}}]({{url}}) ## About\n\ntype:: #type/video/youtube/new\n\n![{{title}}]({{schema:@VideoObject:embedUrl|replace:\"embed/\":\"watch?v=\"}})\n\n## Description\n\n{{schema:@VideoObject:description}}\n\n## Notes\n\nYT=   \n\n\n\n------\n\n \n# {{title}}\n\n![{{schema:name}}]({{url|replace:\"watch?v=\":\"embed/\"}})\n\n{{selectorHtml:#description-inline-expander|remove_html:(\"#structured-description, #snippet, tp-yt-paper-button\")|strip_tags|callout:(\"summary\",\"Description\",true)}}\n\n{{selectorHtml:ytd-engagement-panel-section-list-renderer[visibility$=\\\"EXPANDED\\\"] #segments-container|remove_html:(\"ytd-transcript-section-header-renderer, dom-if\")|strip_tags:(\"yt-formatted-string, yt-img-shadow, ytd-transcript-segment-renderer\")|join|markdown|callout:(\"transcript\",\"Transcript (Youtube)\",true)}}  \n\n\n - [{{selector:.ytp-time-current|first}}]({{url|split:\"&t=\"|first}}&t={{selector:.ytp-time-current|first|slice:0,-3|replace:\"\\:\":\"h\"}}m{{selector:.ytp-time-current|first|slice:-2}}s)",
  "properties": [
    {
      "name": "title",
      "value": "{{schema:name}}",
      "type": "text"
    },
    {
      "name": "title2",
      "value": "{{selector:div.ha:not(:where([style*=\\\"display: none\\\"]) *) > h2|first|safe_name|trim}}",
      "type": "text"
    },
    {
      "name": "title3",
      "value": "{{schema:@VideoObject:name}}",
      "type": "text"
    },
    {
      "name": "url",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "url2",
      "value": "{{schema:@VideoObject:embedUrl|replace:\\\"embed/\\\":\\\"watch?v=\\\"}}",
      "type": "text"
    },
    {
      "name": "url3",
      "value": "{{schema:@VideoObject:embedUrl|replace:\\\"embed/\\\":\\\"watch?v=\\\"}}",
      "type": "text"
    },
    {
      "name": "created",
      "value": "{{time|date:\\\"YYYY-MM-DDTHH:mm:ssZ\\\"}}",
      "type": "datetime"
    },
    {
      "name": "published",
      "value": "{{schema:uploadDate|date:YYYY-MM-DD}}",
      "type": "datetime"
    },
    {
      "name": "published",
      "value": "{{schema:@VideoObject:uploadDate|date_modify:\\\"+10 hours\\\"|date:\\\"YYYY-MM-DD HH:mm:ss\\\"}}",
      "type": "datetime"
    },
    {
      "name": "reviewed",
      "value": "",
      "type": "datetime"
    },
    {
      "name": "author",
      "value": "{{schema:author|wikilink}}",
      "type": "multitext"
    },
    {
      "name": "author2",
      "value": "{{author|split:\\\", \\\"|wikilink|join}}",
      "type": "multitext"
    },
    {
      "name": "channel",
      "value": "{{schema:@VideoObject:author}}",
      "type": "text"
    },
    {
      "name": "Youtube_Channel_Name",
      "value": "{{author|split:\\\", \\\"|first}}",
      "type": "text"
    },
    {
      "name": "description",
      "value": "{{description}}",
      "type": "text"
    },
    {
      "name": "duration",
      "value": "{{schema:@VideoObject:duration|duration}}",
      "type": "text"
    },
    {
      "name": "Youtube_Duration",
      "value": "{{selector:#ytd-player .ytp-time-duration}}",
      "type": "text"
    },
    {
      "name": "duration2",
      "value": "{{schema:@VideoObject:duration|replace:\\\"PT\\\",\\\"\\\",\\\"S\\\",\\\"\\\"}}",
      "type": "text"
    },
    {
      "name": "Youtube_Duration2",
      "value": "{{selector:#ytd-player .ytp-time-duration}}",
      "type": "text"
    },
    {
      "name": "thumbnailUrl",
      "value": "{{schema:thumbnailUrl|slice:0}}",
      "type": "text"
    },
    {
      "name": "thumbnailUrl2",
      "value": "{{schema:@VideoObject:thumbnailUrl|first}}",
      "type": "text"
    },
    {
      "name": "thumbnailUrl3",
      "value": "{{schema:thumbnailUrl|slice:0}}",
      "type": "text"
    },
    {
      "name": "related",
      "value": "[[Videos]]",
      "type": "multitext"
    },
    {
      "name": "type",
      "value": "youtube",
      "type": "text"
    },
    {
      "name": "tags",
      "value": "clippings,videos",
      "type": "multitext"
    },
    {
      "name": "tags2",
      "value": "clippings,videos,{{schema:@VideoObject:genre|kebab}},{{meta:name:keywords|split:\\\", \\\"|kebab|join}}\\\", \\\"{{\\\"an array of tags for an obsidian vault, using snake case when there are multiple words. Omit the words tags:, return only the tags themselves.\\\"}}",
      "type": "multitext"
    }
  ],
  "triggers": [
    "https://www.youtube.com/watch?v="
  ]
}